{
  "name": "jarvis-assistant",
  "version": "1.0.0",
  "description": "A cross-platform voice assistant like Siri for Android and iOS",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace JarvisAssistant.xcworkspace -scheme JarvisAssistant -configuration Release -destination generic/platform=iOS"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.6",
    "react-native-voice": "^3.2.4",
    "react-native-tts": "^4.1.0",
    "react-native-permissions": "^3.8.4",
    "react-native-sound": "^0.11.2",
    "react-native-vector-icons": "^10.0.0",
    "react-native-gesture-handler": "^2.12.1",
    "react-native-reanimated": "^3.4.2",
    "react-native-safe-area-context": "^4.7.1",
    "react-native-screens": "^3.24.0",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/stack": "^6.3.17",
    "react-native-background-timer": "^2.4.1",
    "react-native-keep-awake": "^4.0.0",
    "react-native-device-info": "^10.8.0",
    "react-native-keychain": "^8.1.3",
    "react-native-async-storage": "^1.19.3",
    "axios": "^1.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "^18.0.24",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "4.8.4"
  },
  "jest": {
    "preset": "react-native"
  },
  "keywords": [
    "jarvis",
    "assistant",
    "voice",
    "ai",
    "react-native",
    "cross-platform"
  ],
  "author": "Your Name",
  "license": "MIT"
}